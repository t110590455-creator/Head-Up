<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="22dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/stats_title"
            android:textColor="@color/headup_text_primary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_headup_card_strong"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/current_neck_angle"
                android:textColor="@color/headup_text_secondary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/current_angle_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="0°"
                android:textColor="@color/headup_primary"
                android:textSize="58sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/current_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/posture_status_safe"
                android:textColor="@color/headup_safe"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/parent_dashboard"
            android:textColor="@color/headup_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_headup_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <com.google.mediapipe.examples.poselandmarker.PosturePieChartView
                android:id="@+id/posture_pie_chart"
                android:layout_width="128dp"
                android:layout_height="128dp"
                android:contentDescription="@string/today_posture_distribution" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/safe_percent_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/headup_safe"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/bad_percent_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/headup_danger"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tracked_time_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/headup_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_headup_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/weekly_bad_posture_events"
                android:textColor="@color/headup_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.mediapipe.examples.poselandmarker.PostureLineChartView
                android:id="@+id/posture_line_chart"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/weekly_bad_posture_events" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <include
                android:id="@+id/cumulative_card"
                layout="@layout/item_stat_card"
                android:layout_width="0dp"
                android:layout_height="126dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1" />

            <include
                android:id="@+id/protect_card"
                layout="@layout/item_stat_card"
                android:layout_width="0dp"
                android:layout_height="126dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <include
                android:id="@+id/good_posture_card"
                layout="@layout/item_stat_card"
                android:layout_width="0dp"
                android:layout_height="126dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1" />

            <include
                android:id="@+id/streak_card"
                layout="@layout/item_stat_card"
                android:layout_width="0dp"
                android:layout_height="126dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/daily_tasks"
            android:textColor="@color/headup_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/task_row_one"
            layout="@layout/item_daily_task"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <include
            android:id="@+id/task_row_two"
            layout="@layout/item_daily_task"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <include
            android:id="@+id/task_row_three"
            layout="@layout/item_daily_task"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
