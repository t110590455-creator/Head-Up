<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_headup_card"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/stat_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="★"
        android:textColor="@color/headup_warning"
        android:textSize="26sp" />

    <TextView
        android:id="@+id/stat_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="今日好姿勢"
        android:textColor="@color/headup_text_secondary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/stat_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="2.5h"
        android:textColor="@color/headup_text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />
</LinearLayout>
