<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="82dp"
    android:background="@drawable/bg_headup_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <ImageView
        android:id="@+id/task_check"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_headup_icon_button"
        android:padding="6dp"
        android:src="@drawable/ic_check_headup" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/task_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="維持正確姿勢 30 分鐘"
            android:textColor="@color/headup_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/task_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="30/30 分鐘"
            android:textColor="@color/headup_text_secondary"
            android:textSize="15sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/task_reward"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_headup_reward"
        android:text="+50"
        android:textColor="@color/headup_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
