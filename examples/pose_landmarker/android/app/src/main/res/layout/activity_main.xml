<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_headup_screen"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headup_top_bar"
        android:layout_width="0dp"
        android:layout_height="92dp"
        android:paddingStart="24dp"
        android:paddingTop="18dp"
        android:paddingEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/brand_icon"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_headup_brand"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_headup_arrow" />
        </FrameLayout>

        <TextView
            android:id="@+id/brand_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/app_name"
            android:textColor="@color/headup_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/brand_icon"
            app:layout_constraintEnd_toStartOf="@id/notification_button"
            app:layout_constraintStart_toEndOf="@id/brand_icon"
            app:layout_constraintTop_toTopOf="@id/brand_icon" />

        <ImageButton
            android:id="@+id/notification_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_headup_icon_button"
            android:contentDescription="@string/headup_notification"
            android:padding="12dp"
            android:src="@drawable/ic_bell_headup"
            app:layout_constraintBottom_toBottomOf="@id/brand_icon"
            app:layout_constraintEnd_toStartOf="@id/settings_button"
            app:layout_constraintTop_toTopOf="@id/brand_icon" />

        <ImageButton
            android:id="@+id/settings_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_headup_icon_button"
            android:contentDescription="@string/headup_settings"
            android:padding="12dp"
            android:src="@drawable/ic_settings_headup"
            app:layout_constraintBottom_toBottomOf="@id/brand_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/brand_icon" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:keepScreenOn="true"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@id/navigation_shell"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headup_top_bar"
        app:navGraph="@navigation/nav_graph" />

    <FrameLayout
        android:id="@+id/navigation_shell"
        android:layout_width="0dp"
        android:layout_height="86dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_headup_nav"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/navigation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            app:itemBackground="@drawable/bg_headup_nav_item"
            app:itemIconTint="@color/headup_bottom_nav_tint"
            app:itemRippleColor="@android:color/transparent"
            app:itemTextColor="@color/headup_bottom_nav_tint"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/menu_bottom_nav" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/splash_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/headup_bg_top"
        android:clickable="true"
        android:elevation="40dp"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <ImageView
                android:id="@+id/splash_logo"
                android:layout_width="280dp"
                android:layout_height="164dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:src="@drawable/angel_zero_logo" />

            <TextView
                android:id="@+id/splash_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/splash_ai_processing"
                android:textColor="@color/headup_text_secondary"
                android:textSize="16sp" />
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
