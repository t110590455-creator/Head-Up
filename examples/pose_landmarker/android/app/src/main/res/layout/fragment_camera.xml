<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/camera_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="22dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_scan_headup"
                app:tint="@color/headup_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/scan_view"
                android:textColor="@color/headup_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/camera_card"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_camera_frame"
            android:clipToPadding="true"
            android:padding="2dp">

            <androidx.camera.view.PreviewView
                android:id="@+id/view_finder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:implementationMode="compatible"
                app:scaleType="fitCenter" />

            <com.google.mediapipe.examples.poselandmarker.OverlayView
                android:id="@+id/overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/alarm_toggle_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_headup_icon_button"
                    android:contentDescription="Toggle Alarm"
                    android:padding="12dp"
                    android:src="@drawable/ic_notifications_active"
                    app:tint="@color/headup_text_primary" />

                <ImageButton
                    android:id="@+id/switch_camera_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_headup_icon_button"
                    android:contentDescription="@string/switch_camera"
                    android:padding="12dp"
                    android:src="@drawable/ic_switch_camera"
                    app:tint="@color/headup_text_primary" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/result_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_headup_card_strong"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/posture_scan_results"
                    android:textColor="@color/headup_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/calibration_button"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="@string/calibrate_three_seconds"
                    android:textColor="@color/headup_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/scan_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progress="75"
                android:progressDrawable="@drawable/progress_headup" />

            <TextView
                android:id="@+id/scan_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/posture_reading"
                android:textColor="@color/headup_text_secondary"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <include
                    android:id="@+id/head_tilt_row"
                    layout="@layout/item_posture_result" />

                <include
                    android:id="@+id/neck_curvature_row"
                    layout="@layout/item_posture_result" />

                <include
                    android:id="@+id/shoulder_balance_row"
                    layout="@layout/item_posture_result" />

                <include
                    android:id="@+id/screen_distance_row"
                    layout="@layout/item_posture_result" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
